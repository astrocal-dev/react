{
  "name": "@astrocal/react",
  "version": "0.1.1",
  "type": "module",
  "description": "React SDK for Astrocal — Provider, hooks, and embeddable booking widget for React apps",
  "author": "Astrocal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/astrocal-dev/react"
  },
  "homepage": "https://astrocal.dev",
  "bugs": {
    "url": "https://github.com/astrocal-dev/react/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@astrocal/widget": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@astrocal/widget": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^26.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "scheduling",
    "booking",
    "calendar",
    "react",
    "hooks",
    "widget",
    "astrocal",
    "appointment"
  ]
}
